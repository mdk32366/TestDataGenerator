# Salesforce Configuration
# Copy this file to .env and populate with your actual credentials
# IMPORTANT: .env is in .gitignore and should NEVER be committed to version control

# Salesforce Instance URL (with https://)
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# Salesforce Username (email address)
SALESFORCE_USERNAME=your.email@example.com

# Salesforce Password
SALESFORCE_PASSWORD=your_password

# Salesforce Security Token
# Found in: Setup > Personal Setup > My Personal Information > Reset Security Token
SALESFORCE_SECURITY_TOKEN=your_security_token

# Environment (sandbox or production)
SALESFORCE_ENVIRONMENT=sandbox

# Optional: Data Generation Settings
# RECORDS_PER_OBJECT=100
# REGION=All 50 States
# MONTHS_BACK=6
# MONTHS_FORWARD=6
